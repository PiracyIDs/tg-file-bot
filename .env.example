# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
STORAGE_CHANNEL_ID=-1001234567890

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=tg_file_storage

# ── Security ──────────────────────────────────────────────────────────────────
ALLOWED_USER_IDS=           # Empty = open access
ADMIN_USER_IDS=111111111    # Comma-separated admin user IDs

# ── Quota ─────────────────────────────────────────────────────────────────────
DEFAULT_QUOTA_MB=500        # Per-user quota in MB (0 = unlimited)
DEFAULT_BANDWIDTH_LIMIT_MB=500  # Daily bandwidth limit per user in MB
DEFAULT_DOWNLOAD_LIMIT=5    # Daily download count limit (0 = unlimited)

# ── Auto-Expiry ───────────────────────────────────────────────────────────────
DEFAULT_EXPIRY_DAYS=0       # 0 = no auto-expiry
EXPIRY_CLEANUP_INTERVAL=3600  # Seconds between expiry scans

# ── Token Verification (Shortlink-Based) ───────────────────────────────────────
SHORTLINK_URL=linkshortify.com    # URL shortener service domain
SHORTLINK_API=your_api_key_here    # API key for URL shortener service
VERIFY_EXPIRE_SECONDS=1200          # Token verification expiry time in seconds (default: 20 min)

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=2048
